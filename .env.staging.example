APP_ENV=staging
APP_PORT=8080
DATABASE_URL=postgres://bluecollar:replace-with-password@postgres.example.internal:5432/bluecollarjob?sslmode=require
REDIS_ADDR=redis.example.internal:6379
REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_DB=0
JWT_SECRET=replace-with-strong-random-jwt-secret-at-least-32-chars
ADMIN_TOKEN=replace-with-strong-random-admin-token-at-least-32-chars
CORS_ALLOWED_ORIGINS=https://staging.example.com
FRONTEND_URL=https://staging.example.com
WHATSAPP_PROVIDER=mock
WHATSAPP_VERIFY_TOKEN=replace-with-staging-webhook-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_GRAPH_API_VERSION=v20.0
WHATSAPP_WEBHOOK_SECRET=
DOCUMENT_UPLOAD_ENABLED=false
OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
NOTIFICATION_WORKER_ENABLED=true
NOTIFICATION_WORKER_COUNT=2
NOTIFICATION_POLL_INTERVAL_SECONDS=5
JWT_ISSUER=bluecollarjob-staging
JWT_TTL_HOURS=24
NEXT_PUBLIC_API_BASE_URL=https://api-staging.example.com
NEXT_PUBLIC_APP_ENV=staging
